{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BookingDb": "Server=(localdb)\\mssqllocaldb;Database=BookingServiceDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Booking": {
    "TimeoutMinutes": 15,
    "RefundCutoffHours": 24,
    "ExpiryPollIntervalMinutes": 1
  },
  "Jwt": {
    "Issuer": "BookingService",
    "Audience": "BookingServiceClients",
    "ExpiresInMinutes": 60
  }
}
